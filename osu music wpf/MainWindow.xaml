<Window x:Class="osu_music_wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:osu_music_wpf"
        mc:Ignorable="d"
        Title="Osu! Music Player" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Osu! Music Player"
               FontSize="24"
               Name="a"
               HorizontalAlignment="Center"
               Grid.Row="0"/>

        <TextBlock Name="SongName"
               Text="Unknown song name"
               FontSize="24"
               HorizontalAlignment="Center"
               Grid.Row="1"/>

        <TextBlock Name="TimeLine"
               Text="00:00 - 00:00"
               FontSize="24"
               HorizontalAlignment="Center"
               Grid.Row="3"/>

        <StackPanel Orientation="Horizontal"
                HorizontalAlignment="Center"
                Grid.Row="3"
                Margin="0,5">

            <Button Name="btna"
                Content="Next Song"
                Width="200"
                Height="50"
                Click="btna_Click"
                    Margin="5,0"/>

            <Button Name="btnDT"
                Content="DT"
                Width="80"
                Height="50"
                Click="btnDT_Click"
                Margin="5,0"/>

            <Button Name="btnNC"
                Content="NC"
                Width="80"
                Height="50"
                Click="btnNC_Click"
                Margin="5,0"/>

            <Button Name="btnReset"
                Content="Reset"
                Width="80"
                Height="50"
                Click="btnReset_Click"
                    Margin="5,0"/>
            <Button Name="btnPause"
                Content="Pause"
                Width="80"
                Height="50"
                Click="btnPause_Click"
                Margin="5,0"/>

        </StackPanel>
    </Grid>
</Window>
